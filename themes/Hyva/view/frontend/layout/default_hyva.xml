<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd"
>
    <body>
        <!-- MOVES -->
        <!-- Ensure all AlpineJS scripts load first to guarantee they are available before Magewire initializes. -->
        <move element="script-alpine-js"
              destination="magewire.alpinejs.load"
              before="-"
        />

        <!-- REFERENCES -->
        <!-- Disable loading Alpine.js separately through the theme since it is already included with Magewire. -->
        <referenceBlock name="script-alpine-js"
                        template="Magewirephp_MagewireCompatibilityWithHyva::overwrite/Hyva_Theme/page/js/alpinejs.phtml"
        >
            <block name="script-alpine-js-script"
                   template="Magewirephp_MagewireCompatibilityWithHyva::script.phtml"
                   after="-"
            >
                <block name="script-alpine-js-original"
                       template="Hyva_Theme::page/js/alpinejs.phtml"
                />
            </block>
        </referenceBlock>

        <referenceContainer name="magewire.features">
            <!-- Make the flash messages feature compatible with the Hyvä theme. -->
            <block name="magewire.features.support-magento-flash-messages"
                   template="Magewirephp_MagewireCompatibilityWithHyva::magewire-features/support-magento-flash-messages/support-magento-flash-messages.phtml"
            />
        </referenceContainer>

        <referenceContainer name="magewire.internal.backwards-compatibility">
            <block name="magewire.internal.backwards-compatibility.emits"
                   template="Magewirephp_MagewireCompatibilityWithHyva::js/magewire/internal/backwards-compatibility-emits.phtml"
            />
            <block name="magewire.internal.backwards-compatibility.events"
                   template="Magewirephp_MagewireCompatibilityWithHyva::js/magewire/internal/backwards-compatibility-events.phtml"
            />
        </referenceContainer>
    </body>
</page>
