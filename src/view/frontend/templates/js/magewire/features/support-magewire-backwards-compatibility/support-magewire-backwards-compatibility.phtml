<?php

declare(strict_types=1);

use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;
use Magewirephp\Magewire\ViewModel\Magewire as MagewireViewModel;

/** @var Escaper $escaper */
/** @var Template $block */
/** @var MagewireViewModel $magewireViewModel */

$magewireViewModel = $block->getData('view_model');
$magewireFragment = $magewireViewModel->utils()->fragment();

/** @internal Do not modify to ensure Magewire continues to function correctly. */
?>
<?php $script = $magewireFragment->make()->script()->start() ?>
<script>
    const makeComponentBackwardsCompatible = function(component) {
        return new Proxy(component, {
            get(target, prop, receiver) {
                if (target.effects.bc && prop in target.effects.bc) {
                    const value = target.effects.bc[prop];

                    if (typeof value === 'string' && value.startsWith('path:')) {
                        return value.slice(5).split('.').reduce((obj, key) => obj?.[key], target);
                    }

                    return value;
                }

                return Reflect.get(target, prop, receiver);
            },

            has(target, prop) {
                if (target.effects.bc && prop in target.effects.bc) {
                    return true;
                }

                return Reflect.has(target, prop);
            }
        });
    };

    let magewireBcHooksReady = false;
    let magewireBcHooksResolver = null;
    let magewireBcHooksNotifications = [];

    // A mapping for what the old event became 'old' => 'new'.
    const magewireBcHooksReplacementMapping = {
        'component.initialized': 'component.init',
        'element.initialized': 'element.init',
        'element.removed': 'morph.removed',
        'element.updating': 'morph.updating',
        'message.sent': 'commit',
        'message.failed': 'commit',
        'message.received': 'commit',
        'message.processed': 'commit'
    };

    // Create a promise that resolves when Magewire is available.
    const magewireBcReady = new Promise(resolve => {
        magewireBcHooksResolver = resolve;
    });

    // Function to run a hook when ready.
    const runMagewireBackwardsCompatibleHook = async function(hook, callable) {
        if (! magewireBcHooksNotifications.includes(hook)) {
            const replacement = magewireBcHooksReplacementMapping[hook] || 'TBD';

            <?php if ($magewireViewModel->utils()->magewire()->config()->isInDebugMode()): ?>
                console.warn(`Magewire: Somewhere within your code, you are using a Magewire hook "${hook}". This hook is no longer supported and will eventually be removed. Please upgrade to use "${replacement}" instead. This message is only shown in developer mode.`);
            <?php endif ?>
        }

        magewireBcHooksNotifications.push(hook);

        if (! callable) return;
        // Wait for Magewire to be ready.
        await magewireBcReady;
        // Execute the callable.
        callable();
    };

    // Resolve the promise when magewire:available fires
    document.addEventListener('magewire:available', () => {
        if (! magewireBcHooksReady) {
            magewireBcHooksReady = true;

            // Resolve the promise to release all waiting hooks
            if (magewireBcHooksResolver) {
                magewireBcHooksResolver();
            }
        }
    });

    document.addEventListener('magewire:init', event => {
        <?php /* @deprecated 'component.initialized' has been replaced with 'component.init'. */ ?>
        Magewire.hook('component.init', ({ component, cleanup }) => {
            component = makeComponentBackwardsCompatible(component);

            runMagewireBackwardsCompatibleHook('component.initialized', () => {
                Magewire.trigger('component.initialized', component);
            });

            Object.defineProperty(component, 'deferredActions', {
                get() {
                    return this.queuedUpdates;
                },
                set(v) {
                    this.queuedUpdates = v;
                },

                configurable: true
            });

            <?php /* @deprecated 'component.data' has been replaced with '$wire'. */ ?>
            Object.defineProperty(component, 'data', {
                get() {
                    return this.$wire;
                },

                configurable: true
            });
        });
        <?php /* @deprecated 'element.initialized' has been replaced with 'element.init'. */ ?>
        Magewire.hook('element.init', ({ el, component }) => {
            component = makeComponentBackwardsCompatible(component);

            runMagewireBackwardsCompatibleHook('element.initialized', () => {
                Magewire.trigger('element.initialized', el, component);
            });
        });
        <?php /* @deprecated 'element.updating' has been replaced with 'morph.updating'. */ ?>
        Magewire.hook('morph.updating', ({ el, toEl, component }) => {
            component = makeComponentBackwardsCompatible(component);

            runMagewireBackwardsCompatibleHook('element.updating', () => {
                Magewire.trigger('element.updating', el, toEl, component);
            });
        });
        <?php /* @deprecated 'element.removed' has been replaced with 'morph.removed'. */ ?>
        Magewire.hook('morph.removed', ({ el, component }) => {
            component = makeComponentBackwardsCompatible(component);

            runMagewireBackwardsCompatibleHook('element.removed', () => {
                Magewire.trigger('element.removed', el, component);
            });
        });

        <?php /* @deprecated 'message.sent' has been replaced with 'commit'. */ ?>
        <?php /* @deprecated 'message.failed' has been replaced with 'commit' - fail(). */ ?>
        <?php /* @deprecated 'message.received' has been replaced with 'commit' - succeed(). */ ?>
        <?php /* @deprecated 'message.processed' has been replaced with 'commit' - succeed() - queueMicrotask. */ ?>
        Magewire.hook('commit', ({ component, commit, respond, succeed, fail }) => {
            component = makeComponentBackwardsCompatible(component);

            const generateSignature = () => {
                return (Math.random() + 1).toString(36).substring(8)
            }

            let message = {
                component: component,
                response: {
                    effects: component.effects,
                    serverMemo: component.serverMemo
                },
                updateQueue: []
            }

            if (commit.calls.length !== 0) {
                commit.calls.forEach((value, method) => {
                    const signature = generateSignature();

                    message.updateQueue.push({
                        el: document.activeElement,
                        method: value.method,
                        payload: {
                            id: signature,
                            method: value.method,
                            params: value.params
                        },
                        rejectCallback: () => {},
                        resolveCallback: () => {},
                        signature: signature,
                        skipWatcher: false,
                        type: 'callMethod'
                    });
                });
            }

            if (Object.values(commit.updates).length !== 0) {
                Object.entries(commit.updates).forEach(([property, value]) => {
                    const signature = generateSignature();

                    message.updateQueue.push({
                        el: document.activeElement,
                        payload: {
                            id: signature,
                            name: property,
                            value: value
                        },
                        rejectCallback: () => {},
                        resolveCallback: () => {},
                        signature: signature,
                        skipWatcher: false,
                        type: 'syncInput'
                    })
                });
            }

            runMagewireBackwardsCompatibleHook('message.sent', () => {
                Magewire.trigger('message.sent', message, component);
            });

            succeed(({ snapshot, effects }) => {
                let c = {...component};

                c.effects = effects;
                c.snapshotEncoded = snapshot;
                c.snapshot = JSON.parse(c.snapshotEncoded);

                c = makeComponentBackwardsCompatible(c);

                message.response.effects = c.effects
                message.response.serverMemo = c.effects.bc.serverMemo

                runMagewireBackwardsCompatibleHook('message.received', () => {
                    Magewire.trigger('message.received', message, c);
                });

                queueMicrotask(() => {
                    runMagewireBackwardsCompatibleHook('message.processed', () => {
                        Magewire.trigger('message.processed', message, c);
                    });
                });
            });

            fail(() => {
                // @todo Check if this really needs to dispatch 'message.processed'.
                runMagewireBackwardsCompatibleHook('message.processed', () => {
                    Magewire.trigger('message.processed', message, c);
                });
            });
        });
    });
</script>
<?php $script->end() ?>
