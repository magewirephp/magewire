<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd"
>
    <body>
        <referenceContainer name="magewire.features">
            <!-- Make Hyvä Checkout backwards compatible. -->
            <container name="magewire.features.support-hyva-checkout-backwards-compatibility">
                <block name="magewire.features.support-hyva-checkout-backwards-compatibility.magewire-components"
                       template="Magewirephp_MagewireCompatibilityWithHyva::js/magewire/features/support-hyva-checkout-backwards-compatibility/magewire-components.phtml"
                />
                <block name="magewire.features.support-hyva-checkout-backwards-compatibility.magewire-events"
                       template="Magewirephp_MagewireCompatibilityWithHyva::js/magewire/features/support-hyva-checkout-backwards-compatibility/magewire-events.phtml"
                />
                <block name="magewire.features.support-hyva-checkout-backwards-compatibility.magewire-hooks"
                       template="Magewirephp_MagewireCompatibilityWithHyva::js/magewire/features/support-hyva-checkout-backwards-compatibility/magewire-hooks.phtml"
                />
                <block name="magewire.features.support-hyva-checkout-backwards-compatibility.magewire-attributes"
                       template="Magewirephp_MagewireCompatibilityWithHyva::js/magewire/features/support-hyva-checkout-backwards-compatibility/magewire-attributes.phtml"
                />
            </container>
        </referenceContainer>
    </body>
</page>
